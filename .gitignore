.vscode/settings.json
.vscode/launch.json
.vscode/c_cpp_properties.json
.vscode/tasks.json

# Visual Studio
.vs/
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user

# CLion / JetBrains
.idea/
*.iml

